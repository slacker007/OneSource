  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  opportunity           Opportunity              @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  calculatedByUser      User?                    @relation("OpportunityScorecardCalculator", fields: [calculatedByUserId], references: [id], onDelete: SetNull)
  factorScores          OpportunityScoreFactor[]
  bidDecisions          BidDecision[]

  @@index([organizationId, calculatedAt], map: "opportunity_scorecards_org_calculated_at_idx")
  @@index([opportunityId, calculatedAt], map: "opportunity_scorecards_opportunity_id_calculated_at_idx")
  @@index([calculatedByUserId], map: "opportunity_scorecards_calculated_by_user_id_idx")
  @@index([opportunityId, isCurrent], map: "opportunity_scorecards_opportunity_id_is_current_idx")
  @@map("opportunity_scorecards")
}

model OpportunityScoreFactor {
  id             String               @id @default(cuid()) @map("id")
  scorecardId    String               @map("scorecard_id")
  factorKey      String               @map("factor_key")
  factorLabel    String               @map("factor_label")
  weight         Decimal?             @map("weight") @db.Decimal(5, 2)
  score          Decimal?             @map("score") @db.Decimal(7, 2)
  maximumScore   Decimal?             @map("maximum_score") @db.Decimal(7, 2)
  explanation    String?              @map("explanation") @db.Text
  factorMetadata Json?                @map("factor_metadata")
  sortOrder      Int                  @default(0) @map("sort_order")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  scorecard      OpportunityScorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)

  @@unique([scorecardId, factorKey], map: "opportunity_score_factors_scorecard_id_factor_key_key")
  @@index([scorecardId, sortOrder], map: "opportunity_score_factors_scorecard_id_sort_order_idx")
  @@map("opportunity_score_factors")
}

model BidDecision {
  id                      String                @id @default(cuid()) @map("id")
  organizationId          String                @map("organization_id")
  opportunityId           String                @map("opportunity_id")
  scorecardId             String?               @map("scorecard_id")
  recommendedByUserId     String?               @map("recommended_by_user_id")
  decidedByUserId         String?               @map("decided_by_user_id")
  decisionTypeKey         String?               @map("decision_type_key")
  recommendationOutcome   BidDecisionOutcome?   @map("recommendation_outcome")
  recommendationSummary   String?               @map("recommendation_summary") @db.Text
  recommendationMetadata  Json?                 @map("recommendation_metadata")
  recommendedByActorType  AuditActorType        @default(SYSTEM) @map("recommended_by_actor_type")
  recommendedByIdentifier String?               @map("recommended_by_identifier")
  recommendedAt           DateTime?             @map("recommended_at")
  finalOutcome            BidDecisionOutcome?   @map("final_outcome")
  finalRationale          String?               @map("final_rationale") @db.Text
  decisionMetadata        Json?                 @map("decision_metadata")
  decidedAt               DateTime?             @map("decided_at")
  isCurrent               Boolean               @default(true) @map("is_current")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  organization            Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  opportunity             Opportunity           @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  scorecard               OpportunityScorecard? @relation(fields: [scorecardId], references: [id], onDelete: SetNull)
  recommendedByUser       User?                 @relation("BidDecisionRecommender", fields: [recommendedByUserId], references: [id], onDelete: SetNull)
  decidedByUser           User?                 @relation("BidDecisionDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, decidedAt], map: "bid_decisions_org_decided_at_idx")
  @@index([opportunityId, decidedAt], map: "bid_decisions_opportunity_id_decided_at_idx")
  @@index([opportunityId, isCurrent], map: "bid_decisions_opportunity_id_is_current_idx")
  @@index([scorecardId], map: "bid_decisions_scorecard_id_idx")
  @@index([recommendedByUserId], map: "bid_decisions_recommended_by_user_id_idx")
  @@index([decidedByUserId], map: "bid_decisions_decided_by_user_id_idx")
  @@map("bid_decisions")
}

model SourceImportDecision {
  id                      String                     @id @default(cuid()) @map("id")
  organizationId          String                     @map("organization_id")
  sourceConnectorConfigId String?                    @map("source_connector_config_id")
  sourceRecordId          String                     @map("source_record_id")
  targetOpportunityId     String?                    @map("target_opportunity_id")
  requestedByUserId       String?                    @map("requested_by_user_id")
  decidedByUserId         String?                    @map("decided_by_user_id")
  requestedByActorType    SourceExecutionActorType   @default(USER) @map("requested_by_actor_type")
  mode                    SourceImportDecisionMode   @map("mode")
  status                  SourceImportDecisionStatus @default(PENDING) @map("status")
  rationale               String?                    @map("rationale")
  decisionMetadata        Json?                      @map("decision_metadata")
  importPreviewPayload    Json?                      @map("import_preview_payload")
  requestedAt             DateTime                   @default(now()) @map("requested_at")
  decidedAt               DateTime?                  @map("decided_at")
  createdAt               DateTime                   @default(now()) @map("created_at")
  updatedAt               DateTime                   @updatedAt @map("updated_at")
  organization            Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  connectorConfig         SourceConnectorConfig?     @relation(fields: [sourceConnectorConfigId], references: [id], onDelete: SetNull)
  sourceRecord            SourceRecord               @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)
  targetOpportunity       Opportunity?               @relation("SourceImportDecisionTargetOpportunity", fields: [targetOpportunityId], references: [id], onDelete: SetNull)
  requestedByUser         User?                      @relation("SourceImportDecisionRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  decidedByUser           User?                      @relation("SourceImportDecisionDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, requestedAt], map: "source_import_decisions_organization_id_requested_at_idx")
  @@index([sourceConnectorConfigId], map: "source_import_decisions_source_connector_config_id_idx")
  @@index([sourceRecordId], map: "source_import_decisions_source_record_id_idx")
  @@index([targetOpportunityId], map: "source_import_decisions_target_opportunity_id_idx")
  @@index([requestedByUserId], map: "source_import_decisions_requested_by_user_id_idx")
  @@index([decidedByUserId], map: "source_import_decisions_decided_by_user_id_idx")
  @@map("source_import_decisions")
}

model SourceSearchResult {
  searchExecutionId String                @map("search_execution_id")
  sourceRecordId    String                @map("source_record_id")
  resultRank        Int?                  @map("result_rank")
  observedAt        DateTime              @default(now()) @map("observed_at")
  searchExecution   SourceSearchExecution @relation(fields: [searchExecutionId], references: [id], onDelete: Cascade)
  sourceRecord      SourceRecord          @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)

  @@id([searchExecutionId, sourceRecordId])
  @@index([sourceRecordId], map: "source_search_results_source_record_id_idx")
  @@map("source_search_results")
}

model SourceSyncRunRecord {
  syncRunId      String                 @map("sync_run_id")
  sourceRecordId String                 @map("source_record_id")
  syncAction     SourceSyncRecordAction @default(DISCOVERED) @map("sync_action")
  observedAt     DateTime               @default(now()) @map("observed_at")
  errorMessage   String?                @map("error_message")
  syncRun        SourceSyncRun          @relation(fields: [syncRunId], references: [id], onDelete: Cascade)
  sourceRecord   SourceRecord           @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)

  @@id([syncRunId, sourceRecordId])
  @@index([sourceRecordId], map: "source_sync_run_records_source_record_id_idx")
  @@map("source_sync_run_records")
}
