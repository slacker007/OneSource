generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum AuditActorType {
  USER
  SYSTEM
}

model Organization {
  id        String             @id @default(cuid()) @map("id")
  name      String             @map("name")
  slug      String             @unique @map("slug")
  status    OrganizationStatus @default(ACTIVE) @map("status")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  users     User[]
  roles     Role[]
  auditLogs AuditLog[]

  @@map("organizations")
}

model User {
  id             String       @id @default(cuid()) @map("id")
  organizationId String       @map("organization_id")
  email          String       @unique @map("email")
  emailVerified  DateTime?    @map("email_verified")
  name           String?      @map("name")
  image          String?      @map("image")
  status         UserStatus   @default(INVITED) @map("status")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  accounts       Account[]
  sessions       Session[]
  roles          UserRole[]
  auditLogs      AuditLog[]   @relation("AuditActor")

  @@index([organizationId], map: "users_organization_id_idx")
  @@map("users")
}

model Role {
  id             String       @id @default(cuid()) @map("id")
  organizationId String       @map("organization_id")
  key            String       @map("key")
  name           String       @map("name")
  description    String?      @map("description")
  isSystem       Boolean      @default(false) @map("is_system")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  users          UserRole[]

  @@unique([organizationId, key], map: "roles_organization_id_key_key")
  @@index([organizationId], map: "roles_organization_id_idx")
  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId], map: "user_roles_role_id_idx")
  @@map("user_roles")
}

model Account {
  id                String  @id @default(cuid()) @map("id")
  userId            String  @map("user_id")
  type              String  @map("type")
  provider          String  @map("provider")
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String? @map("scope")
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], map: "accounts_provider_provider_account_id_key")
  @@index([userId], map: "accounts_user_id_idx")
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid()) @map("id")
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime @map("expires")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_idx")
  @@map("sessions")
}

model VerificationToken {
  identifier String   @map("identifier")
  token      String   @unique @map("token")
  expires    DateTime @map("expires")

  @@id([identifier, token])
  @@map("verification_tokens")
}

model AuditLog {
  id              String         @id @default(cuid()) @map("id")
  organizationId  String?        @map("organization_id")
  actorUserId     String?        @map("actor_user_id")
  actorType       AuditActorType @default(USER) @map("actor_type")
  actorIdentifier String?        @map("actor_identifier")
  action          String         @map("action")
  targetType      String         @map("target_type")
  targetId        String?        @map("target_id")
  targetDisplay   String?        @map("target_display")
  summary         String?        @map("summary")
  metadata        Json?          @map("metadata")
  ipAddress       String?        @map("ip_address")
  userAgent       String?        @map("user_agent")
  occurredAt      DateTime       @default(now()) @map("occurred_at")
  organization    Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorUser       User?          @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt], map: "audit_logs_organization_id_occurred_at_idx")
  @@index([actorUserId, occurredAt], map: "audit_logs_actor_user_id_occurred_at_idx")
  @@index([targetType, targetId], map: "audit_logs_target_type_target_id_idx")
  @@map("audit_logs")
}
